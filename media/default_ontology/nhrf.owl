  <!-- Director -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/Director">
    <rdfs:label>Director</rdfs:label>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#HumanSubject"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#HumanSubject"/>
  </rdf:Description>	

  <!-- GeneralDirector -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/GeneralDirector">
    <rdfs:label>General Director</rdfs:label>
    <rdf:type rdf:resource="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/Director"/>
    <rdfs:subClassOf rdf:resource="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/Director"/>
  </rdf:Description>

  <!-- DeputyDirector -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/DeputyDirector">
    <rdfs:label>Deputy Director</rdfs:label>
    <rdf:type rdf:resource="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/Director"/>
    <rdfs:subClassOf rdf:resource="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/Director"/>
  </rdf:Description>

  <!-- DivisionHead -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/DivisionHead">
