  </rdf:Description>

  <!-- TeamLeader -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/TeamLeader">
    <rdfs:label>Team Leader</rdfs:label>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#HumanSubject"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#HumanSubject"/>
  </rdf:Description>	

  <!-- ProjectLeader -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/ProjectLeader">
