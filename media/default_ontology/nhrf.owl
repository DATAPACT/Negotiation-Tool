    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#HumanSubject"/>
  </rdf:Description>

  <!-- JuniorResearcher -->
  <rdf:Description rdf:about="https://www.upcast-project.eu/upcast-vocab/1.0/dso/nhrf/JuniorResearcher">
